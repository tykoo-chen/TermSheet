OPENAI_API_KEY=your-openai-api-key

# Local dev (SQLite) — used when DATABASE_URI is empty
DATABASE_URL=sqlite+aiosqlite:///./termsheet.db

# Remote Supabase PostgreSQL — takes precedence over DATABASE_URL
DATABASE_URI=postgresql+asyncpg://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres
